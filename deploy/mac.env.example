# Copy to backend/.env on Mac
# Clear Cloudinary templates every time the API starts (default: true)
CLEAR_TEMPLATES_ON_START=true

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

FACEFUSION_PYTHON=venv-ff/bin/python
FACEFUSION_EXECUTION_PROVIDERS=cpu
FACEFUSION_PROCESSORS=face_swapper face_enhancer
FACEFUSION_SWAP_MODEL=hyperswap_1a_256
FACEFUSION_PIXEL_BOOST=512x512
SWAP_MAX_EDGE=1280
