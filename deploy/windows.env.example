# Copy to backend\.env on your Windows PC (RTX 4060 Ti + 32 GB RAM).
# Requires: NVIDIA driver + CUDA 12.x for GPU (see deploy/WINDOWS.md steps).

CLEAR_TEMPLATES_ON_START=true

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Windows paths (relative to backend\ folder)
FACEFUSION_PYTHON=venv-ff\Scripts\python.exe

# GPU — good defaults for RTX 4060 Ti (8 GB VRAM)
FACEFUSION_EXECUTION_PROVIDERS=cuda
FACEFUSION_PROCESSORS=face_swapper face_enhancer
FACEFUSION_SWAP_MODEL=hyperswap_1a_256
FACEFUSION_PIXEL_BOOST=512x512
FACEFUSION_SWAP_WEIGHT=0.85
FACEFUSION_ENHANCER_MODEL=gfpgan_1.4
FACEFUSION_ENHANCER_BLEND=80
SWAP_MAX_EDGE=1280

# Optional: longer timeout for large photos (seconds)
FACEFUSION_TIMEOUT_SEC=600
